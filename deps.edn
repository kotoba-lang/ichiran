{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc → portable to JVM / SCI / ClojureScript / GraalVM). Same runtime
 ;; kekkai/tayori/teian/koyomi ride on; a tally/rollup-sheet generation
 ;; control plane is just another sealed-intelligence ⊣ independent-governor
 ;; StateGraph.
 :deps {io.github.kotoba-lang/langgraph
        {:git/url "https://github.com/kotoba-lang/langgraph.git"
         :sha "5b4e5e70837b849b14b6a5800894e3be202ad5fa"}
        ;; canonical did:key + IPNS-name derivation (ADR-2607050100) — same
        ;; copy kekkai/tayori/teian's CACAO issuance uses.
        io.github.kotoba-lang/ed25519
        {:sha "fdcefb9f1b83461fee54d04b63e374fa301ee847"}
        io.github.kotoba-lang/ipns
        {:sha "f2563eb1cb010c96f6dec1dfbd468fac93367498"}
        ;; ichiran does NOT reimplement the workbook/tab/cell/formula/chart EDN
        ;; model — it holds kotoba-lang/sheets content verbatim as draft
        ;; :content (ADR-2607062030).
        io.github.kotoba-lang/sheets
        {:local/root "../sheets"}}
 :aliases
 {;; offline workspace dev — pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain {:local/root "../langchain"}}}
  ;; clojure -M:dev:run  → drive a tally workbook draft/publish through one TallyActor
  :run {:main-opts ["-m" "ichiran.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main" "--lint" "src" "test" "--fail-level" "error"]}}}
